            "dependencyConditions": [
              "Completed"
            ]
          }
        ],
        "policy": {
          "timeout": "0.00:05:00"
        },
        "typeProperties": {
          "notebook": {
            "referenceName": "nb_sql_execute",
            "type": "NotebookReference"
          },
          "parameters": {
            "control_sql_endpoint": {
              "value": "@pipeline().parameters.control_sql_endpoint",
              "type": "Expression"
            },
            "control_database_name": {
              "value": "@pipeline().parameters.control_database_name",
              "type": "Expression"
            },
            "stored_procedure_name": {
              "value": "[audit].[usp_LogPipelineEnd]",
              "type": "String"
            },
            "stored_procedure_params_json": {
              "value": "@{json(concat('{', '\"RunId\":\"', guid(), '\",\"Status\":\"SUCCEEDED\"}'))}",
              "type": "Expression"
            },
            "key_vault_url": {
              "value": "@pipeline().parameters.key_vault_url",
              "type": "Expression"
            }
          }
        }
      }
    ],
    "parameters": {
      "control_sql_endpoint": {
        "type": "String",
        "defaultValue": "<workspace>.sql.azuresynapse.net"
      },
      "control_database_name": {
        "type": "String",
