              "value": "lh_silver",
              "type": "String"
            },
            "schema_name": {
              "value": "cleaned",
              "type": "String"
            },
            "dry_run": {
              "value": "false",
              "type": "String"
            }
          }
        }
      },
      {
        "name": "Maintenance Gold",
        "type": "Notebook",
        "dependsOn": [
          {
            "activity": "Maintenance Silver",
