          "timeout": "0.02:00:00",
          "retry": 1
        },
        "typeProperties": {
          "notebook": {
            "referenceName": "nb_lakehouse_maintenance",
            "type": "NotebookReference"
          },
          "parameters": {
            "lakehouse_name": {
              "value": "lh_bronze",
              "type": "String"
            },
            "schema_name": {
              "value": "raw",
              "type": "String"
            },
            "dry_run": {
              "value": "false",
              "type": "String"
            }
          }
        }
      },
      {
