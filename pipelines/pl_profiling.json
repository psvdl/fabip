{
  "name": "pl_profiling",
  "properties": {
    "description": "Weekly data profiling for all tables (Fabric-compatible)",
    "activities": [
      {
        "name": "Profile Bronze Tables",
        "type": "ForEach",
        "dependsOn": [],
        "typeProperties": {
          "items": {
            "value": "[\"raw\"]",
            "type": "Expression"
          },
          "isSequential": true,
          "activities": [
            {
              "name": "Profile Table",
              "type": "Notebook",
              "typeProperties": {
                "notebook": {
                  "referenceName": "nb_data_profiling",
                  "type": "NotebookReference"
                },
                "parameters": {
                  "lakehouse": {
                    "value": "lh_bronze",
                    "type": "String"
                  },
                  "schema": {
                    "value": "@item()",
                    "type": "Expression"
                  },
                  "table": {
                    "value": "customers",
                    "type": "String"
                  },
                  "sample_size": {
                    "value": "100000",
                    "type": "String"
                  },
                  "control_sql_endpoint": {
                    "value": "@pipeline().parameters.control_sql_endpoint",
                    "type": "Expression"
                  },
                  "control_database_name": {
                    "value": "@pipeline().parameters.control_database_name",
                    "type": "Expression"
                  },
                  "key_vault_url": {
                    "value": "@pipeline().parameters.key_vault_url",
                    "type": "Expression"
                  }
                }
              }
            }
          ]
        }
      }
    ],
    "parameters": {
      "control_sql_endpoint": {
        "type": "String",
        "defaultValue": "<workspace>.sql.azuresynapse.net"
      },
      "control_database_name": {
        "type": "String",
        "defaultValue": "fabric_control"
      },
      "key_vault_url": {
        "type": "String",
        "defaultValue": "https://<vault>.vault.azure.net/"
      }
    },
    "variables": {},
    "annotations": [],
    "lastPublishTime": "2026-06-21T00:00:00Z"
  }
}
