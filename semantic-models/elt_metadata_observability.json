    "relationships": [
      {
        "name": "EntityRuns_to_PipelineRuns",
        "fromTable": "EntityRuns",
        "fromColumn": "RunId",
        "toTable": "PipelineRuns",
        "toColumn": "RunId",
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "GoldModelRuns_to_PipelineRuns",
        "fromTable": "GoldModelRuns",
        "fromColumn": "RunId",
        "toTable": "PipelineRuns",
        "toColumn": "RunId",
        "crossFilteringBehavior": "bothDirections"
      }
    ],
    "measures": [
      {
        "name": "Total Pipeline Runs",
        "expression": "COUNTROWS(PipelineRuns)",
        "formatString": "#,##0"
      },
      {
        "name": "Success Rate",
        "expression": "DIVIDE(COUNTROWS(FILTER(PipelineRuns, PipelineRuns[Status] = \"SUCCEEDED\")), COUNTROWS(PipelineRuns), 0)",
        "formatString": "0.00%"
      },
      {
        "name": "Avg Duration (s)",
        "expression": "AVERAGE(PipelineRuns[DurationSeconds])",
        "formatString": "#,##0"
      },
      {
        "name": "Total Rows Processed",
        "expression": "SUM(PipelineRuns[RowsRead])",
        "formatString": "#,##0"
      }
    ]
