    "relationships": [
      {
        "name": "fact_orders_to_dim_customers",
        "fromTable": "fact_orders",
        "fromColumn": "CustomerID",
        "toTable": "dim_customers",
        "toColumn": "CustomerID",
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "fact_orders_to_Date",
        "fromTable": "fact_orders",
        "fromColumn": "OrderDate",
        "toTable": "Date",
        "toColumn": "Date",
        "crossFilteringBehavior": "singleDirection"
      }
    ],
    "measures": [
      {
        "name": "Total Revenue",
        "expression": "SUM(fact_orders[OrderTotal])",
        "formatString": "$#,##0.00"
      },
      {
        "name": "Total Orders",
        "expression": "COUNTROWS(fact_orders)",
        "formatString": "#,##0"
      },
      {
        "name": "Average Order Value",
        "expression": "DIVIDE([Total Revenue], [Total Orders], 0)",
        "formatString": "$#,##0.00"
      },
      {
        "name": "YTD Revenue",
        "expression": "TOTALYTD([Total Revenue], Date[Date])",
        "formatString": "$#,##0.00"
      },
      {
        "name": "YoY Growth",
        "expression": "VAR CurrentYear = [Total Revenue] VAR PreviousYear = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR(Date[Date])) RETURN DIVIDE(CurrentYear - PreviousYear, PreviousYear, 0)",
        "formatString": "0.00%"
      }
    ],
    "roles": [
